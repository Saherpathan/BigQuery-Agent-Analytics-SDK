# Google Cloud Platform Configuration
# For local development, use Application Default Credentials (ADC) or service account

# Using service account JSON file (Recommended for local development)
GCP_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Production / hosted deployments only: pin the single table the dashboard
# may read. Required when NODE_ENV=production or running on Vercel.
DASHBOARD_BQ_PROJECT_ID=your-project-id
DASHBOARD_BQ_DATASET_ID=your_dataset
DASHBOARD_BQ_TABLE_ID=agent_events
